<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Generate PPT - CheatCodeIARE</title>
    <link rel="stylesheet" href="/styles/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .ppt-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            background: rgba(255, 255, 255, 0.03);
            padding: 40px;
            border-radius: 15px;
            border: 2px solid #ff00ff;
            box-shadow: 0 0 15px rgba(255, 0, 255, 0.2);
            backdrop-filter: blur(10px);
            max-width: 600px;
            width: 100%;
            margin: 20px;
        }

        .ppt-title {
            font-family: 'Orbitron', sans-serif;
            color: #fff;
            text-shadow: 0 0 10px #ff00ff;
            margin-bottom: 30px;
            font-size: 2rem;
            text-align: center;
        }

        .user-info {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
            width: 100%;
            justify-content: space-between;
        }

        .info-box {
            background: rgba(0, 0, 0, 0.5);
            padding: 10px 20px;
            border: 1px solid #39ff14;
            color: #39ff14;
            font-family: 'Orbitron', sans-serif;
            font-size: 0.9rem;
            border-radius: 5px;
            flex: 1;
            text-align: center;
        }

        .input-group {
            width: 100%;
            margin-bottom: 20px;
        }

        .input-group label {
            display: block;
            color: #ff00ff;
            font-family: 'Orbitron', sans-serif;
            margin-bottom: 8px;
            font-size: 0.9rem;
        }

        .input-group input,
        .input-group textarea {
            width: 100%;
            padding: 12px;
            background: rgba(0, 0, 0, 0.5);
            border: 1px solid #333;
            border-radius: 5px;
            color: #fff;
            font-family: 'Poppins', sans-serif;
            font-size: 1rem;
            outline: none;
            box-sizing: border-box;
            transition: all 0.3s ease;
        }

        .input-group input:focus,
        .input-group textarea:focus {
            border-color: #39ff14;
            box-shadow: 0 0 10px rgba(57, 255, 20, 0.3);
        }

        .generate-btn {
            width: 100%;
            padding: 15px;
            background: transparent;
            color: #39ff14;
            border: 2px solid #39ff14;
            font-family: 'Orbitron', sans-serif;
            font-weight: bold;
            font-size: 1.2rem;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 10px;
            text-transform: uppercase;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .generate-btn:hover {
            background: #39ff14;
            color: #050505;
            box-shadow: 0 0 20px rgba(57, 255, 20, 0.8);
        }

        .loading {
            display: none;
            color: #39ff14;
            margin-top: 15px;
            font-family: 'Orbitron', sans-serif;
            font-size: 1rem;
            text-align: center;
            text-shadow: 0 0 10px rgba(57, 255, 20, 0.5);
        }

        .loading i {
            margin-left: 10px;
            font-size: 1.2rem;
            display: inline-block;
            animation: fa-spin 2s infinite linear;
            color: #39ff14;
        }

        @keyframes fa-spin {
            0% {
                transform: rotate(0deg);
            }
            100% {
                transform: rotate(360deg);
            }
        }
    </style>
</head>

<body>
    <!-- Persistent Header -->
    <div class="header">
        <div class="headerLeft" style="cursor: pointer;" onclick="window.location.href='/'">
            <img src="/images/CheatCodeIARE.png" alt="img" class="logo">
            <p class="title">CheatCodeIARE</p>
        </div>
        <div class="headerRight">
            <button class="signupbtn" onclick="window.location.href='/'">HOME</button>
        </div>
    </div>

    <div class="content">
        <div class="ppt-container">
            <h1 class="ppt-title">PPT GENERATOR</h1>

            <div class="user-info">
                <div class="info-box">Name: <%= user.name %>
                </div>
                <div class="info-box">ID: <%= user.studentId %>
                </div>
            </div>

            <form id="pptForm" action="/generate-ppt" method="POST">
                <div class="input-group">
                    <label>Department</label>
                    <input type="text" name="department" required placeholder="e.g. CSE">
                </div>
                <div class="input-group">
                    <label>Subject</label>
                    <input type="text" name="subject" required placeholder="e.g. Artificial Intelligence">
                </div>
                <div class="input-group">
                    <label>Problem Statement</label>
                    <textarea name="problemStatement" rows="4" required placeholder="Describe your topic..."></textarea>
                </div>
                <button type="submit" class="generate-btn" id="generateBtn">
                    <i class="fa-solid fa-bolt"></i> GENERATE PPT
                </button>
                <div id="loading" class="loading">Generating Cybernetic Content... <i
                        class="fa-solid fa-spinner fa-spin"></i></div>
            </form>
        </div>
    </div>

    <script>
        document.getElementById('pptForm').addEventListener('submit', async function (e) {
        e.preventDefault();
        const btn = document.getElementById('generateBtn');
        const loading = document.getElementById('loading');
        if (btn.disabled) return;
        btn.disabled = true;
        btn.style.display = 'none';
        loading.style.display = 'block';

        const body = new URLSearchParams(new FormData(this)).toString();
        try {
            const res  = await fetch('/generate-ppt', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body });
            const data = await res.json();
            if (data.queued) { window.location.href = '/queue'; }
            else { loading.textContent = '❌ ' + (data.error || 'Unknown error'); btn.disabled = false; btn.style.display = 'flex'; }
        } catch (err) {
            loading.textContent = '❌ Network error. Please try again.';
            btn.disabled = false; btn.style.display = 'flex';
        }
    });
    </script>

    <!-- Vercel Web Analytics -->
    <script>
        window.va = window.va || function () { (window.vaq = window.vaq || []).push(arguments) };
    </script>
    <script defer src="/_vercel/insights/script.js"></script>
</body>

</html>
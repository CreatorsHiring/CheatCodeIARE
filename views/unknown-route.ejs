<!-- Micro-interaction: Mouse Glow Effect -->
<div class="fixed pointer-events-none w-[600px] h-[600px] bg-primary/5 rounded-full blur-[100px] -translate-x-1/2 -translate-y-1/2 opacity-0 transition-opacity duration-700 z-0" id="mouse-glow"></div>
<script>
        const glow = document.getElementById('mouse-glow');
        document.addEventListener('mousemove', (e) => {
            glow.style.left = e.clientX + 'px';
            glow.style.top = e.clientY + 'px';
            glow.style.opacity = '1';
        });

        // Add subtle glitch randomly
        setInterval(() => {
            const h1 = document.querySelector('h1');
            if (Math.random() > 0.95) {
                h1.classList.add('glitch-effect');
                setTimeout(() => h1.classList.remove('glitch-effect'), 500);
            }
        }, 2000);
    </script>
